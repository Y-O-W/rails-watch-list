<div id="<%= dom_id card %>">
  <div>
    <strong>Poster:</strong>
    <%= image_tag "#{movie.poster_url}", alt: "#{movie.title}", width: 200 %>
  </div>
  
  <div>
    <strong>Title:</strong>
    <%= movie.title %>
  </div>

  <div>
    <strong>Overview:</strong>
    <%= movie.overview %>
  </div>

  <div>
    <strong>Rating:</strong>
    <%= movie.rating %>
  </div>

  <div>
    <strong>Comment:</strong>
    <%= bookmark.comment %>
  </div>

</div>
